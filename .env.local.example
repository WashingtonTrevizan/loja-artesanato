# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Painel do Supabase -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Numero de WhatsApp da artesa, com DDI e DDD, so digitos. Ex: 5511999998888
NEXT_PUBLIC_WHATSAPP_ARTESA=5511999998888

# Nome da loja exibido no site
NEXT_PUBLIC_NOME_LOJA=Ateliê da Cida

# --- Fase 1 / Entrega 2: Mercado Pago (preencher quando ativar pagamento) ---
# Endereco publico do site (sem barra no final). Em producao: https://sua-loja.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Access Token do Mercado Pago (TESTE comeca com TEST-). Painel: Suas integracoes -> credenciais
MP_ACCESS_TOKEN=
# Service role key do Supabase (Project Settings -> API -> service_role). NUNCA exponha no navegador.
SUPABASE_SERVICE_ROLE_KEY=
