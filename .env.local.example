# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Painel do Supabase -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Numero de WhatsApp da artesa, com DDI e DDD, so digitos. Ex: 5511999998888
NEXT_PUBLIC_WHATSAPP_ARTESA=5511999998888

# Nome da loja exibido no site
NEXT_PUBLIC_NOME_LOJA=Ateliê da Cida
